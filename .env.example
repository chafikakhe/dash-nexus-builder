# ========================================
# DASH NEXUS BUILDER - Environment Variables
# ========================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!

# ========================================
# SUPABASE CONFIGURATION
# ========================================
# Get these values from your Supabase project dashboard
# https://app.supabase.com

# Your Supabase project URL
# Example: https://your-project.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous public API key
# This is safe to expose in the browser (it's public)
# Find it in: Settings → API → Project API keys → Public (anon)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================================
# EMAIL NOTIFICATIONS (EmailJS)
# ========================================
# Configure EmailJS for sending invitation and notification emails
# Sign up at: https://www.emailjs.com

# EmailJS Service ID (identifies your email service)
# Get from EmailJS dashboard: Admin → Add Service
VITE_EMAILJS_SERVICE_ID=service_xxxxxxxxx

# EmailJS Template ID (for invitation emails)
# Create template in EmailJS and copy the ID
# Variables in template: to_email, org_name, invite_link, invited_by
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxxxx

# EmailJS Public Key
# Get from EmailJS Account section → Copy public key
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# OPTIONAL - DEVELOPMENT SETTINGS
# ========================================

# API request timeout in milliseconds (default: 30000)
# VITE_API_TIMEOUT=30000

# Enable debug logging (default: false)
# VITE_DEBUG_MODE=false

# API endpoint (if using custom backend instead of Supabase)
# VITE_API_URL=http://localhost:3000/api

# ========================================
# OPTIONAL - ANALYTICS & MONITORING
# ========================================

# Sentry error tracking (optional)
# VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Google Analytics (optional)
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ========================================
# SETUP INSTRUCTIONS
# ========================================
# 1. Rename this file to .env.local
# 2. Get your Supabase credentials:
#    - Go to https://app.supabase.com
#    - Create or select your project
#    - Go to Settings → API
#    - Copy "Project URL" and "Public (anon) Key"
# 3. Set up EmailJS (optional, for invitations):
#    - Go to https://www.emailjs.com
#    - Create account and get Service ID, Template ID, Public Key
# 4. Save the file
# 5. Restart your dev server (npm run dev)
#
# For production, use environment secrets instead of .env files!
